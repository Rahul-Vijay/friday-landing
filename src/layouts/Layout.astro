---
import "../styles/global.css";
import StructuredData from "../components/StructuredData.astro";
import WaitlistModal from "../components/WaitlistModal.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Friday: set a goal, it hires the crew",
  description = "AI agent harness. Give it a goal; it hires the best model for each task and loops until the work is verified and done. Runs on your own Claude and Codex subscriptions, local-first. Launching soon; join the waitlist.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0c0c17" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Friday" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={new URL("/og.png", Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Friday logo: a grid of rounded squares forming an F, next to the wordmark." />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/og.png", Astro.site)} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <StructuredData />
    <script
      is:inline
      defer
      data-website-id="dfid_Arz4LiYF6Cy86N8DiP1o1"
      data-domain="getfriday.dev"
      src="https://datafa.st/js/script.js"></script>
    <script is:inline>
      document.documentElement.classList.add('js-reveal');
      try {
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('mock-anim');
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <div class="canvas-atmosphere"></div>
    <slot />
    <WaitlistModal />
  </body>
</html>
